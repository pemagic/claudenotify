{
  "name": "claudenotify",
  "version": "1.0.0",
  "description": "A generic notification integration tool for Claude Code and Codex using Bark GET requests.",
  "author": {
    "name": "pemagic"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/index.js\" --client claude"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/index.js\" --client claude"
          }
        ]
      }
    ]
  }
}
